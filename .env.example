SUPABASE_URL=https://pnzwjqjovxxdikxtfngq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # server-side only — get from Supabase dashboard, never ship to the browser
NEXT_PUBLIC_SUPABASE_URL=https://pnzwjqjovxxdikxtfngq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBuendqcWpvdnh4ZGlreHRmbmdxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMwMzk0ODQsImV4cCI6MjA5ODYxNTQ4NH0.-Yj59z2QkfcXURqYLti1bdFuqPTEXmXAqSKB4HXTOgU

# App-level encryption for cin7_instances.application_key_encrypted (AES-GCM key, 32 random bytes, base64)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Sync
SYNC_SHARED_SECRET=                    # guards /api/sync (and /api/import, /settings/instances) from unauthenticated calls
CRON_SECRET=                           # set to the SAME VALUE as SYNC_SHARED_SECRET — Vercel Cron auto-sends
                                        # `Authorization: Bearer $CRON_SECRET` when it calls GET /api/sync on schedule
RATE_LIMIT_RPS=1                       # Cin7 Core limit is 60/min (~1/sec); over-limit returns 503, no Retry-After header — see docs/cin7-api-findings.md

# Lemon Squeezy (subscription billing) — Store > Product > Variant created in the Lemon Squeezy dashboard
LEMONSQUEEZY_STORE_SLUG=               # your store's subdomain, e.g. "cin7toolbox" for cin7toolbox.lemonsqueezy.com
LEMONSQUEEZY_BUY_LINK_ID=              # the product's "Buy Link" UUID (Products > [product] > Share button) —
                                        # NOT the variant ID or product ID shown elsewhere in the dashboard
LEMONSQUEEZY_API_KEY=                  # for the customer-portal lookup only (Settings > API in the LS dashboard)
LEMONSQUEEZY_WEBHOOK_SECRET=           # set when creating the webhook (Settings > Webhooks), pointed at /api/webhooks/lemonsqueezy
LEMONSQUEEZY_STORE_ACTIVE=             # set to "true" once LS finishes store activation (tax verification) — until then the
                                        # Billing section stays hidden for orgs that haven't subscribed yet (see checkoutAvailableFor)
